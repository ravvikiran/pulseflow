# PulseFlow Environment Variables
# Copy this file to .env and fill in the values

# Database (MySQL) — optional, app works without it using simulated data
DATABASE_URL=mysql://user:password@localhost:3306/pulseflow

# Server port (default: 3000)
PORT=3000

# JWT secret for session cookies (any random string, used for auth)
JWT_SECRET=change-this-to-a-random-secret

# Optional: API key to protect cron/scheduled job endpoints
# If not set, scheduled endpoints are open (fine for local dev)
CRON_API_KEY=
